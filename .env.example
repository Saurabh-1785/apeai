# ===========================================
# ApeAI — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# ------------------------------------------
# Supabase (REQUIRED for database storage)
# Get these from: https://supabase.com → Project Settings → API
# ------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ------------------------------------------
# Slack Integration (OPTIONAL)
# Create a Slack app at: https://api.slack.com/apps
# Enable Socket Mode + Event Subscriptions
# ------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# ------------------------------------------
# GitHub Webhook (OPTIONAL)
# Set this same secret when creating the webhook
# in your GitHub repo: Settings → Webhooks
# ------------------------------------------
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ------------------------------------------
# Google AI (REQUIRED for Layer 2 embeddings)
# Get your key from: https://aistudio.google.com/app/apikey
# ------------------------------------------
GOOGLE_API_KEY=your-google-api-key

# ------------------------------------------
# Server Configuration
# ------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
